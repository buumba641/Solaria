PORT=8787

# devnet | mainnet-beta
SOLANA_CLUSTER=devnet
# optional override
SOLANA_RPC_URL=

SOLARIA_PROGRAM_ID=
# Oracle keypair JSON array: [12,34,...]
ORACLE_KEYPAIR_JSON=

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

LIFI_BASE_URL=https://li.quest/v1

# Security
ADMIN_API_KEY=
# Comma-separated list of allowed origins (leave empty to allow all)
CORS_ORIGINS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SENSITIVE_RATE_LIMIT_MAX=20

# Demo mode (disables API key checks when true)
PUBLIC_DEMO_MODE=false
